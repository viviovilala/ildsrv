# Environment configuration file for the application.
# Copy this to .env and fill in your actual values.
YII_ENV=dev
YII_DEBUG=true

# Session cookies: false for http://localhost Docker; true when PUBLIC_DOMAIN uses https
COOKIE_SECURE=false

# Database configuration
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=
DB_DATABASE=ildis_v4
DB_DATABASE_PORT=3306

PUBLIC_DOMAIN=http://ildis-frontend.test

# Cookie validation keys (generate with: php -r "echo Yii::$app->security->generateRandomString();")
COOKIE_VALIDATION_KEY_BE=
COOKIE_VALIDATION_KEY_FE=

# reCAPTCHA (backend login/CMS) — set false for local dev without Google keys
RECAPTCHA_ENABLED=false
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=